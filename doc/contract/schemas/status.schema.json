{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://thin-edge.io/ot-connector/status.schema.json",
  "title": "OT Connector Status & Capability Messages",
  "description": "Retained status, link, and capability descriptor messages published by a connector.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/health" },
    { "$ref": "#/$defs/link" },
    { "$ref": "#/$defs/capabilities" }
  ],
  "$defs": {
    "health": {
      "title": "Service health",
      "type": "object",
      "required": ["status"],
      "additionalProperties": true,
      "properties": {
        "status": { "enum": ["up", "down"] },
        "time": { "type": "string", "format": "date-time" }
      }
    },
    "link": {
      "title": "Device link status",
      "type": "object",
      "required": ["status"],
      "additionalProperties": false,
      "properties": {
        "status": { "enum": ["connected", "disconnected", "degraded"] },
        "since": { "type": "string", "format": "date-time" },
        "reason": { "type": "string" }
      }
    },
    "capabilities": {
      "title": "Capability descriptor",
      "type": "object",
      "required": ["protocol", "version", "modes"],
      "additionalProperties": false,
      "properties": {
        "protocol": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "modes": {
          "type": "array",
          "minItems": 1,
          "items": { "enum": ["raw", "typed"] },
          "uniqueItems": true
        },
        "datatypes": {
          "type": "array",
          "items": {
            "enum": [
              "bool",
              "int8", "uint8",
              "int16", "uint16",
              "int32", "uint32",
              "int64", "uint64",
              "float32", "float64",
              "string", "bytes"
            ]
          },
          "uniqueItems": true
        },
        "point_kinds": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "command_verbs": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "features": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "subscribe": { "type": "boolean", "default": false }
      }
    }
  },
  "examples": [
    { "status": "up", "time": "2026-05-30T09:59:00.000Z" },
    { "status": "connected", "since": "2026-05-30T09:59:00.000Z" },
    {
      "protocol": "modbus",
      "version": "0.1.0",
      "modes": ["raw", "typed"],
      "datatypes": ["bool", "int16", "uint16", "int32", "uint32", "float32", "float64"],
      "point_kinds": ["coil", "discrete_input", "holding_register", "input_register"],
      "command_verbs": ["write"],
      "features": ["polling", "bitfield"],
      "subscribe": false
    }
  ]
}
