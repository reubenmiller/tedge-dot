# Restrict this flow instance to a single connector point id (matches sample.point).
# Leave empty to map every point the flow receives into a measurement series.
point = ""

# Convert boolean (coil) samples into 1/0 measurements.
include_boolean = "true"

# Only publish when the scaled value differs from the previously emitted one (per point).
# Reduces cloud traffic for slowly-changing values. "true" or "false".
on_change = "false"

# Minimum absolute change (in engineering units, vs the last emitted value) required to emit.
# Implies change detection. 0 = disabled.
deadband = "0"

# Per-signal rate limit: drop readings that arrive within this interval of the last emitted
# one ("500ms", "10s", "1m"). Empty/0 = disabled.
min_interval = ""

# Debounce: a changed value must stay stable for this long (by sample timestamps) before it is
# emitted; implies change detection. Empty/0 = disabled.
debounce = ""

# Every setting above is a flow-wide default. A signal can override any of them through the
# point's free-form `meta` table in the connector config, echoed by the runtime in every
# sample envelope, e.g.:
#   [[device.point]]
#   id = "boiler_temp"
#   meta = { on_change = true, deadband = 0.5, min_interval = "10s" }

# Batch every series of a device into a single measurement message, flushed every
# combine_interval. Reduces the number of measurements created in the cloud. "true" or "false".
combine = "false"
combine_interval = "10s"

# Output measurement shaping.
#   target_topic - where to publish. Empty -> te/device/<device>///m/<group>
#   group        - measurement group (the outer JSON key). Empty -> the sample's protocol
#   series       - series name (inner JSON key). Empty -> the sample's point id
# A signal can also name its own measurement through the point's meta table (wins over the
# flow-wide group/series, like the other meta overrides):
#   meta = { measurement = { group = "Environment", series = "Temperature" } }
# The engineering unit is a per-signal property declared on the connector point (point.unit) and
# echoed in the sample, so it is applied automatically (series value becomes { value, unit }).
target_topic = ""
group = ""
series = ""

# Remap signals by point-id naming convention. When set, a point id containing this separator is
# split once into "<group><sep><series>" (e.g. "." maps "Environment.Temperature" -> group
# "Environment", series "Temperature"). Explicit group/series above still win. Empty = disabled,
# so point ids that already contain dots are left untouched.
point_separator = ""

